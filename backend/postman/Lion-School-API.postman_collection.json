{
  "info": {
    "name": "Lion School API",
    "description": "Postman collection for Lion School Django API endpoints.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://127.0.0.1:8000" },
    { "key": "api_prefix", "value": "/api" },
    { "key": "token", "value": "" },
    { "key": "course_id", "value": "1" },
    { "key": "module_id", "value": "1" },
    { "key": "quiz_id", "value": "1" },
    { "key": "question_id", "value": "1" },
    { "key": "lesson_id", "value": "1" },
    { "key": "enrollment_id", "value": "1" },
    { "key": "review_id", "value": "1" }
  ],
  "item": [
    {
      "name": "API Root",
      "item": [
        {
          "name": "GET API Root",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}{{api_prefix}}/"
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "POST Register",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"student1@example.com\",\n  \"username\": \"student1\",\n  \"first_name\": \"Student\",\n  \"last_name\": \"One\",\n  \"password\": \"Password123!\",\n  \"password_confirm\": \"Password123!\",\n  \"role\": \"student\"\n}"
            },
            "url": "{{base_url}}{{api_prefix}}/auth/register/"
          }
        },
        {
          "name": "POST Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const data = pm.response.json();",
                  "  if (data.token) pm.collectionVariables.set('token', data.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"student1@example.com\",\n  \"password\": \"Password123!\"\n}"
            },
            "url": "{{base_url}}{{api_prefix}}/auth/login/"
          }
        },
        {
          "name": "GET Profile",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}{{api_prefix}}/auth/profile/"
          }
        },
        {
          "name": "PUT Profile",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"first_name\": \"Updated\",\n  \"last_name\": \"Name\",\n  \"bio\": \"Learning platform user\"\n}"
            },
            "url": "{{base_url}}{{api_prefix}}/auth/profile/"
          }
        }
      ]
    },
